generator client {
  provider = "prisma-client"
  output   = "../app/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// App access is controlled — accounts are created only via the seed script,
// there is no public signup. Data (recipes, planner, grocery) stays shared.
model User {
  id           String   @id @default(cuid())
  email        String   @unique
  passwordHash String
  name         String?
  createdAt    DateTime @default(now())
}

model Recipe {
  id           String        @id @default(cuid())
  name         String
  servings     Int?
  time         Int?
  difficulty   String?
  category     String?
  favorite     Boolean       @default(false)
  link         String?
  imageUrl     String?
  notionId     String?       @unique
  notes        String?
  ingredients  Ingredient[]
  instructions Instruction[]
  weekPlans    WeekPlan[]
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
}

model GroceryItem {
  id          String       @id @default(cuid())
  name        String       @unique
  nameRo      String?
  category    String?
  unit        String?
  unit2       String?
  conversion  Float?
  kcal        Float?
  carbs       Float?
  fat         Float?
  protein     Float?
  unitWeight  Float?
  notionId    String?      @unique
  createdAt   DateTime     @default(now())
  ingredients Ingredient[]
  nameMappings IngredientNameMapping[]
}

model Ingredient {
  id            String       @id @default(cuid())
  recipeId      String
  recipe        Recipe       @relation(fields: [recipeId], references: [id], onDelete: Cascade)
  groceryItemId String?
  groceryItem   GroceryItem? @relation(fields: [groceryItemId], references: [id])
  groupName     String?
  groupOrder    Int          @default(0)
  quantity      Float?
  unit          String?
  notes         String?
  order         Int          @default(0)
}

model Instruction {
  id        String  @id @default(cuid())
  recipeId  String
  recipe    Recipe  @relation(fields: [recipeId], references: [id], onDelete: Cascade)
  step      Int
  text      String
  isSection Boolean @default(false)
  instrType String? // "numbered" | "bullet" | "plain" | null = numbered (legacy)
}

model WeekPlan {
  id        String   @id @default(cuid())
  recipeId  String
  recipe    Recipe   @relation(fields: [recipeId], references: [id], onDelete: Cascade)
  weekStart DateTime
  dayOfWeek Int
  mealType  String
  servings  Int      @default(1)
  createdAt DateTime @default(now())
}

// Remembers a manual "raw ingredient name → grocery item" mapping made during import,
// so the same raw name auto-resolves on future imports. (Replaces data/ingredient_name_mappings.json.)
model IngredientNameMapping {
  id              String      @id @default(cuid())
  rawName         String      @unique // lowercased raw ingredient name from a recipe
  groceryItemId   String
  groceryItem     GroceryItem @relation(fields: [groceryItemId], references: [id], onDelete: Cascade)
  groceryItemName String
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt
}

// Remembers a unit-conversion choice for an ingredient's foreign unit made during import.
// (Replaces data/unit_choices.json.) key = "ingredientname|foreignunit"; 1 foreignUnit = rate × targetUnit.
model UnitRule {
  id          String   @id @default(cuid())
  key         String   @unique
  targetUnit  String
  rate        Float
  foreignUnit String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}
